---
// Para ativar o email subscribe, crie uma conta no Buttondown (buttondown.email)
// e substitua 'seu-usuario' pelo seu username.
const BUTTONDOWN_USERNAME = 'seu-usuario';
const RSS_URL = `${Astro.site ?? 'https://amphora-site.vercel.app'}rss.xml`;

const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  currentPath === path || currentPath.startsWith(path + '/');
---

<aside class="sidebar">
  <a href="/" class="sidebar-name">Nicholas Velten</a>

  <nav>
    <a href="/" class:list={[{ active: currentPath === '/' }]}>Escrita</a>
    <a href="/leituras" class:list={[{ active: isActive('/leituras') }]}>Leituras</a>
    <a href="/agora" class:list={[{ active: isActive('/agora') }]}>Agora</a>
    <a href="/sobre" class:list={[{ active: isActive('/sobre') }]}>Sobre</a>
  </nav>

  <div class="sidebar-tags">
    <span>Tags</span>
    <a href="/tags/notas">#notas</a>
    <a href="/tags/livros">#livros</a>
    <a href="/tags/tecnologia">#tecnologia</a>
  </div>

  <div class="sidebar-footer">
    <div class="rss-wrap">
      <button class="rss-btn" id="rss-copy" data-url={RSS_URL}>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="5" cy="19" r="3"/>
          <path d="M4 4a16 16 0 0 1 16 16h-3A13 13 0 0 0 4 7V4z"/>
          <path d="M4 11a9 9 0 0 1 9 9H10a6 6 0 0 0-6-6v-3z"/>
        </svg>
        <span id="rss-label">RSS</span>
      </button>
      <div class="rss-tooltip">Copiar link do feed</div>
    </div>

    <form
      class="subscribe-inline"
      action={`https://buttondown.email/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`}
      method="post"
      target="_blank"
    >
      <input
        class="subscribe-inline-input"
        type="email"
        name="email"
        placeholder="email"
        required
      />
      <button class="subscribe-inline-btn" type="submit">→</button>
    </form>
  </div>
</aside>

<script>
  const btn = document.getElementById('rss-copy') as HTMLButtonElement;
  const label = document.getElementById('rss-label');

  btn?.addEventListener('click', async () => {
    const url = btn.dataset.url ?? '';
    try {
      await navigator.clipboard.writeText(url);
      btn.classList.add('copied');
      if (label) label.textContent = 'Copiado!';
      setTimeout(() => {
        btn.classList.remove('copied');
        if (label) label.textContent = 'RSS';
      }, 2000);
    } catch {
      window.open(url, '_blank');
    }
  });
</script>
