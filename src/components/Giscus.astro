---
const REPO = 'nfvelten/amphora-site';
const REPO_ID = 'R_kgDORh8mCg';
const CATEGORY = 'General';
const CATEGORY_ID = 'DIC_kwDORh8mCs4C3_Eg';
---

<div class="comments">
  <button class="comments-toggle" id="toggle-comments">
    Mostrar comentários
  </button>
  <div id="giscus-container" style="display:none">
    <script
      src="https://giscus.app/client.js"
      data-repo={REPO}
      data-repo-id={REPO_ID}
      data-category={CATEGORY}
      data-category-id={CATEGORY_ID}
      data-mapping="pathname"
      data-strict="1"
      data-reactions-enabled="1"
      data-emit-metadata="1"
      data-input-position="bottom"
      data-theme="preferred_color_scheme"
      data-lang="pt"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </div>
</div>

<script>
  const btn = document.getElementById('toggle-comments');
  const container = document.getElementById('giscus-container');
  btn?.addEventListener('click', () => {
    const visible = container?.style.display !== 'none';
    if (container) container.style.display = visible ? 'none' : 'block';
    if (btn) btn.textContent = visible ? 'Mostrar comentários' : 'Ocultar comentários';
  });
</script>
