---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'O que faz Nicholas Velten?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Nicholas Velten é engenheiro de software full-stack com foco em construir sistemas escaláveis e bem estruturados. Trabalha na Alloha Fibra desenvolvendo aplicações e serviços com Java, TypeScript, Vue.js e Node.js, com cerca de quatro anos de experiência em telecomunicações, fintechs e startups de produto.',
      },
    },
    {
      '@type': 'Question',
      name: 'Quais tecnologias Nicholas Velten usa?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No trabalho, Nicholas usa principalmente Java, TypeScript, Vue.js e Node.js. No ambiente pessoal, usa Linux com Hyprland como gerenciador de janelas, Neovim como editor de código e Obsidian para gestão de conhecimento.',
      },
    },
    {
      '@type': 'Question',
      name: 'Como entrar em contato com Nicholas Velten?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Você pode entrar em contato pelo email nikvelten@gmail.com ou pelo LinkedIn em linkedin.com/in/nicholasveltenfullstack.',
      },
    },
    {
      '@type': 'Question',
      name: 'O que é publicado neste site?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'O site reúne escrita pessoal sobre tecnologia, ferramentas de desenvolvimento e aprendizados. Também inclui registros de leitura (livros lidos, em andamento e planejados) e uma página "agora" com o que está acontecendo no momento. Sem frequência definida — só o que vale registrar.',
      },
    },
  ],
};
---

<BaseLayout
  title="Sobre"
  description="Conheça Nicholas Velten — engenheiro de software full-stack com experiência em Java, TypeScript e Vue.js. Projetos, contato e mais."
  jsonLd={faqSchema}
>
  <Sidebar slot="sidebar" />
  <article>
    <header class="post-header">
      <h1>Sobre</h1>
    </header>
    <div class="prose">
      <p>
        Sou Nicholas Velten, engenheiro de software full-stack com foco em construir sistemas
        escaláveis e bem estruturados. Trabalho atualmente na Alloha Fibra, onde desenvolvo
        aplicações e serviços em Java, TypeScript, Vue.js e Node.js. Tenho cerca de quatro anos
        de experiência profissional, passando por empresas de telecomunicações, fintechs e
        startups de produto.
      </p>

      <p>
        Gosto de entender sistemas por inteiro — do banco de dados ao componente de interface.
        Tenho apreço por código limpo, arquitetura que faz sentido e ferramentas que ficam do
        jeito que você quer. No dia a dia uso Linux com Hyprland, Neovim como editor e Obsidian
        para manter um vault de notas técnicas e pessoais.
      </p>

      <p>
        Fora do trabalho, leio bastante — ficção científica, HQs e livros técnicos. Frequento
        sebos sempre que posso. Bebo mate e tererê. Sou de Maringá, Paraná.
      </p>

      <p>
        Este site é onde publico o que estou pensando, aprendendo e lendo.
        Sem frequência definida — só o que vale registrar.
      </p>

      <p>
        <a href="/curriculo">Currículo</a> ·
        <a href="https://www.linkedin.com/in/nicholasveltenfullstack" target="_blank" rel="noopener">LinkedIn</a> ·
        <a href="mailto:nikvelten@gmail.com">nikvelten@gmail.com</a>
      </p>

      <h2>Perguntas frequentes</h2>

      <h3>O que faz Nicholas Velten?</h3>
      <p>
        Engenheiro de software full-stack com foco em sistemas escaláveis. Trabalho com Java,
        TypeScript, Vue.js e Node.js na Alloha Fibra, com passagem por telecomunicações,
        fintechs e startups de produto.
      </p>

      <h3>Quais tecnologias você usa?</h3>
      <p>
        No trabalho: Java, TypeScript, Vue.js, Node.js. No ambiente pessoal: Linux com Hyprland,
        Neovim e Obsidian. Prefiro ferramentas que dão controle e que funcionam do jeito que
        você configura.
      </p>

      <h3>O que é publicado aqui?</h3>
      <p>
        Escrita sobre tecnologia, ferramentas e aprendizados. Registros de leitura. Uma página
        "agora" com o que está acontecendo. Sem pauta fixa — só o que vale registrar.
      </p>

      <h3>Como entrar em contato?</h3>
      <p>
        Email: <a href="mailto:nikvelten@gmail.com">nikvelten@gmail.com</a> ou
        <a href="https://www.linkedin.com/in/nicholasveltenfullstack" target="_blank" rel="noopener">LinkedIn</a>.
      </p>
    </div>
  </article>
</BaseLayout>
