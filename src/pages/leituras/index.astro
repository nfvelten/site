---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';

const leituras = (await getCollection('leituras', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const lendo     = leituras.filter(l => l.data.status === 'lendo');
const lidos     = leituras.filter(l => l.data.status === 'lido');
const querLer   = leituras.filter(l => l.data.status === 'quero-ler');

const statusLabel: Record<string, string> = {
  lendo: 'Lendo', lido: 'Lido', 'quero-ler': 'Quero ler',
};
---

<BaseLayout title="Leituras">
  <Sidebar slot="sidebar" />

  {lendo.length > 0 && (
    <section style="margin-bottom: 2.5rem">
      <h2 style="margin-bottom: 1.25rem">Lendo agora</h2>
      <ul class="post-list">
        {lendo.map(l => (
          <li class="post-item">
            <div class="post-meta">
              <span class={`status-badge status-${l.data.status}`}>{statusLabel[l.data.status]}</span>
              {l.data.genero && <span>{l.data.genero}</span>}
            </div>
            <a href={`/leituras/${l.id.replace(/\.md$/, '')}`} class="post-title">{l.data.title}</a>
            <p class="post-excerpt" style="margin-top: 0.2rem; font-style: italic; font-size: 0.85rem; color: var(--tx-3)">{l.data.autor}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  {lidos.length > 0 && (
    <section style="margin-bottom: 2.5rem">
      <h2 style="margin-bottom: 1.25rem">Lidos</h2>
      <ul class="post-list">
        {lidos.map(l => (
          <li class="post-item">
            <div class="post-meta">
              <time datetime={l.data.date.toISOString()}>
                {l.data.date.toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' })}
              </time>
              {l.data.genero && <span>{l.data.genero}</span>}
            </div>
            <a href={`/leituras/${l.id.replace(/\.md$/, '')}`} class="post-title">{l.data.title}</a>
            <p class="post-excerpt" style="margin-top: 0.2rem; font-style: italic; font-size: 0.85rem; color: var(--tx-3)">{l.data.autor}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  {querLer.length > 0 && (
    <section>
      <h2 style="margin-bottom: 1.25rem">Quero ler</h2>
      <ul class="post-list">
        {querLer.map(l => (
          <li class="post-item">
            <div class="post-meta">
              <span class="status-badge status-quero-ler">Quero ler</span>
              {l.data.genero && <span>{l.data.genero}</span>}
            </div>
            <a href={`/leituras/${l.id.replace(/\.md$/, '')}`} class="post-title">{l.data.title}</a>
            <p class="post-excerpt" style="margin-top: 0.2rem; font-style: italic; font-size: 0.85rem; color: var(--tx-3)">{l.data.autor}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  {leituras.length === 0 && (
    <p style="color: var(--tx-3); font-size: 0.9rem;">Nenhuma leitura registrada ainda.</p>
  )}
</BaseLayout>
