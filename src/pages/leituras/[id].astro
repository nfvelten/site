---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const leituras = await getCollection('leituras', ({ data }) => !data.draft);
  return leituras.map(l => ({
    params: { id: l.id.replace(/\.mdx?$/, '') },
    props: { livro: l },
  }));
}

const { livro } = Astro.props;
const { Content } = await render(livro);

const statusLabel: Record<string, string> = {
  lendo: 'Lendo', lido: 'Lido', 'quero-ler': 'Quero ler',
};
---

<PostLayout
  title={livro.data.title}
  date={livro.data.date}
  tags={livro.data.tags}
>
  <p style="color: var(--tx-2); font-style: italic; margin-bottom: 0.25rem">{livro.data.autor}</p>
  <span class={`status-badge status-${livro.data.status}`} style="display:inline-block; margin-bottom: 2rem">
    {statusLabel[livro.data.status]}
  </span>
  <Content />
</PostLayout>
