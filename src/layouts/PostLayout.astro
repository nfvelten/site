---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: string;
  readingTime?: number;
}

const { title, date, tags = [], description, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('pt-BR', {
  day: 'numeric', month: 'long', year: 'numeric',
});

const postUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://nicholas-velten.xyz').toString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description ?? `${title} — Nicholas Velten`,
  datePublished: date.toISOString(),
  url: postUrl,
  inLanguage: 'pt-BR',
  author: {
    '@type': 'Person',
    name: 'Nicholas Velten',
    url: 'https://nicholas-velten.xyz/sobre',
  },
  publisher: {
    '@type': 'Person',
    name: 'Nicholas Velten',
    url: 'https://nicholas-velten.xyz',
  },
};
---

<BaseLayout title={title} description={description ?? `${title} — Nicholas Velten`} jsonLd={articleSchema}>
  <Sidebar slot="sidebar" />
  <article>
    <header class="post-header">
      <h1>{title}</h1>
      <div class="meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {readingTime && <span>{readingTime} min de leitura</span>}
        {tags.map(tag => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <Giscus />
  </article>
</BaseLayout>
