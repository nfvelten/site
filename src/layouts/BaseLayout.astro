---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  jsonLd?: Record<string, unknown> | null;
}
const {
  title = 'Nicholas Velten',
  description = 'Site pessoal de Nicholas Velten — engenheiro de software full-stack. Escrita sobre tecnologia, leituras e aprendizados.',
  image = '/og-default.png',
  jsonLd = null,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://nicholas-velten.xyz');
const fullTitle = title === 'Nicholas Velten' ? title : `${title} — Nicholas Velten`;

const schemaWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://nicholas-velten.xyz/#website',
  url: 'https://nicholas-velten.xyz',
  name: 'Nicholas Velten',
  description: 'Site pessoal de Nicholas Velten — engenheiro de software full-stack. Escrita sobre tecnologia, leituras e aprendizados.',
  inLanguage: 'pt-BR',
};

const schemaOrganization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://nicholas-velten.xyz/#organization',
  name: 'Nicholas Velten',
  url: 'https://nicholas-velten.xyz',
  logo: {
    '@type': 'ImageObject',
    url: 'https://nicholas-velten.xyz/favicon.svg',
    contentUrl: 'https://nicholas-velten.xyz/favicon.svg',
  },
  sameAs: [
    'https://www.linkedin.com/in/nicholasveltenfullstack',
  ],
};

const schemaPerson = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': 'https://nicholas-velten.xyz/#person',
  name: 'Nicholas Velten',
  url: 'https://nicholas-velten.xyz/sobre',
  image: 'https://nicholas-velten.xyz/favicon.svg',
  jobTitle: 'Engenheiro de Software Full-Stack',
  worksFor: {
    '@type': 'Organization',
    name: 'Alloha Fibra',
  },
  email: 'nikvelten@gmail.com',
  sameAs: [
    'https://www.linkedin.com/in/nicholasveltenfullstack',
  ],
};

const schemaWebPage = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${canonical.toString()}#webpage`,
  url: canonical.toString(),
  name: fullTitle,
  description: description,
  inLanguage: 'pt-BR',
  isPartOf: { '@id': 'https://nicholas-velten.xyz/#website' },
  about: { '@id': 'https://nicholas-velten.xyz/#person' },
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <!-- Tema por horário: light 6h–18h, dark fora desse intervalo. Inline para evitar flash. -->
    <script is:inline>
      (function () {
        var h = new Date().getHours();
        document.documentElement.setAttribute('data-theme', (h >= 6 && h < 18) ? 'light' : 'dark');
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />

    <!-- SEO -->
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonical)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, canonical)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Nicholas Velten" href="/rss.xml" />
    <title>{fullTitle}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaWebSite)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrganization)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaPerson)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <div class="wrapper">
      <slot name="sidebar" />
      <main class="main">
        <slot />
      </main>
    </div>
  </body>
</html>
