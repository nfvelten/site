---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const {
  title = 'Nicholas Velten',
  description = 'Escrita, leituras e notas.',
  image = '/og-default.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://nicholasvelten.com');
const fullTitle = title === 'Nicholas Velten' ? title : `${title} — Nicholas Velten`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <!-- Tema por horário: light 6h–18h, dark fora desse intervalo. Inline para evitar flash. -->
    <script is:inline>
      (function () {
        var h = new Date().getHours();
        document.documentElement.setAttribute('data-theme', (h >= 6 && h < 18) ? 'light' : 'dark');
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />

    <!-- SEO -->
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonical)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, canonical)} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Nicholas Velten" href="/rss.xml" />
    <title>{fullTitle}</title>
    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <div class="wrapper">
      <slot name="sidebar" />
      <main class="main">
        <slot />
      </main>
    </div>
  </body>
</html>
